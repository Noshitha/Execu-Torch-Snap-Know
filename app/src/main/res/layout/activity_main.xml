<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ── Live camera preview ── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:scaleType="fillCenter"/>

    <!-- ── Transparent face overlay (drawn on top of camera) ── -->
    <com.snapknow.app.ui.FaceOverlayView
        android:id="@+id/face_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Model status chip (top-left) ── -->
    <TextView
        android:id="@+id/model_status_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/chip_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/start_camera_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Start camera"
        android:textSize="15sp"
        app:icon="@android:drawable/ic_menu_camera"
        app:backgroundTint="#CC1A73E8"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/model_status_chip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Flip camera button (top-right) ── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/flip_camera_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_camera"
        android:contentDescription="Flip camera"
        android:visibility="gone"
        app:fabSize="mini"
        app:backgroundTint="#80000000"
        app:tint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── "Remember this face" button — appears when a face is detected ── -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/remember_face_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Remember face"
        android:textSize="15sp"
        android:visibility="gone"
        app:icon="@android:drawable/ic_menu_save"
        app:backgroundTint="#CC1A73E8"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/bottom_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Bottom info card ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Status line: "Listening…" / "Tap mic to speak" -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start the camera or tap Start Mic when you're ready"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:letterSpacing="0.05"/>

            <TextView
                android:id="@+id/voice_prompt_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Use Remember Face, then tap Start Mic to say the person's name and relationship."
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/object_summary_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Object highlights will appear here when the camera is on."
                android:textColor="#FFD28B57"
                android:textSize="13sp" />

            <!-- Response text — what the assistant said -->
            <TextView
                android:id="@+id/response_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="visible"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/start_mic_button"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Mic"
                    android:textAllCaps="false"
                    app:backgroundTint="#CC1A73E8"
                    android:textColor="@android:color/white"
                    app:icon="@android:drawable/ic_btn_speak_now" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/stop_mic_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="Stop Mic"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:icon="@android:drawable/ic_media_pause"
                    app:iconTint="@android:color/white"
                    app:strokeColor="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/show_saved_faces_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Show saved faces"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:icon="@android:drawable/ic_menu_agenda"
                    app:iconTint="@android:color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/manage_saved_faces_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Manage memories"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconTint="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/describe_scene_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="Describe scene"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconTint="@android:color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ask_scene_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="Ask scene"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconTint="@android:color/white" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
